# ─────────────────────────────────────────────────────────────────────────────
# Attendance Management System – Environment Configuration
# Copy this file to ".env" and fill in real values.
# Then install python-dotenv and add `from dotenv import load_dotenv; load_dotenv()`
# at the top of app.py  (optional – env vars also work system-wide / in CI).
# ─────────────────────────────────────────────────────────────────────────────

# Flask
FLASK_SECRET_KEY=change-me-to-something-random

# ── Meta WhatsApp Cloud API (Official) ────────────────────────────────────────
# Get these from https://developers.facebook.com → Your App → WhatsApp → API Setup
#   1. Create a Meta Developer App at https://developers.facebook.com
#   2. Add the "WhatsApp" product
#   3. Go to WhatsApp → API Setup and copy:
#      - Phone number ID  (the numeric ID under "From" phone number)
#      - Access Token      (temporary or permanent system user token)
WHATSAPP_ACCESS_TOKEN=your_meta_whatsapp_access_token_here
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here

# Graph API version (default: v21.0)
GRAPH_API_VERSION=v21.0

# Set to "true" to actually send messages; "false" = log-only / dry-run
WHATSAPP_ENABLED=true

# ── Automated Daily Summary Schedule ─────────────────────────────────────────
# Time to send the daily summary (24h format, Pakistan time UTC+5)
DAILY_SUMMARY_HOUR=9
DAILY_SUMMARY_MINUTE=30

# Time to send the absent alert (24h format, Pakistan time UTC+5)
ABSENT_ALERT_HOUR=11
ABSENT_ALERT_MINUTE=0

# ── Excel data file (optional override) ──────────────────────────────────────
# EXCEL_PATH=Emp_data.xlsx
